# Local OpenClaw/Docker runtime state
data/*
!data/.gitkeep
workspace/*
!workspace/.gitkeep
.openclaw/
.env
.env.*
!.env.example
!docker/seed-workspace/services/pi_liaison/.env.template
logs/
!docker/seed-workspace/logs/
!docker/seed-workspace/logs/README.md
*.log
secrets/
*.pem
*.key
*.token

# Track only explicit workspace templates that are part of this repo.
!workspace/services/
workspace/services/*
!workspace/services/pi_liaison/
workspace/services/pi_liaison/*
!workspace/services/pi_liaison/.env.template

# Docker temp and local override files
.docker/
docker-compose.override.yml
docker-compose.*.local.yml
*.tar
*.pid

# Python/MkDocs local output
.cache/
.venv/
__pycache__/
site/
dist/

# OS/editor files
.DS_Store
.idea/
.vscode/
